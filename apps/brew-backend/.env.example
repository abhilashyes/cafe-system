# Copy to .env (never commit real secrets — use AWS Secrets Manager in prod).
NODE_ENV=development
PORT=3000

# Runtime profile selects all adapters at the composition root:
#   demo (default) = mock auth/Razorpay + in-memory data (no cloud needed)
#   live           = real adapters (wired progressively in M2/M4)
BREW_PROFILE=demo

# Firebase Auth / Identity Platform (live profile only). The backend verifies
# Firebase ID tokens against this project. On Cloud Run, GOOGLE_CLOUD_PROJECT is
# set automatically and can be used instead.
FIREBASE_PROJECT_ID=your-firebase-project-id

# --- AWS Cognito (mocked in dev) ---
COGNITO_USER_POOL_ID=ap-south-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=ap-south-1

# --- Razorpay (mocked in dev) ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=__from_secrets_manager__
RAZORPAY_WEBHOOK_SECRET=__from_secrets_manager__

# --- Adapters: 'mock' (default in dev) or 'aws'/'razorpay' (prod) ---
AUTH_ADAPTER=mock
PAYMENT_ADAPTER=mock
EVENT_BUS=memory
