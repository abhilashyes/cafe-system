{
  "name": "cafe-system",
  "version": "0.1.0",
  "private": true,
  "description": "Project Brew — multi-tenant café operations platform (monorepo). Flutter customer app lives in brew-mobile-customer.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "demo": "node scripts/demo-flow.mjs",
    "contracts:lint": "pnpm --filter @brew/contracts lint"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
